# ─────────────────────────────────────────────
# Todo en Uno · Car Wash Services — Variables de entorno
# Copia este archivo a ".env.local" y rellena con tus credenciales de Supabase.
# (Settings → API en tu proyecto de Supabase)
# ─────────────────────────────────────────────

# URL del proyecto Supabase (ej: https://xxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Clave pública "anon" (segura para el frontend; la seguridad real la da RLS)
VITE_SUPABASE_ANON_KEY=
